<?xml version="1.0" encoding="UTF-8"?>
<!--
  Mipuy — iOS expense-ingestion Shortcut (SOURCE, unsigned).

  Purpose: a Wallet/Transaction automation runs this Shortcut on every Apple Pay
  charge; it POSTs { token, merchant, amount } to /api/transaction, which
  categorizes and drops it into the user's expense log. See docs/ios-shortcut-setup.md.

  This is the UNSIGNED source. iOS 15+ only imports SIGNED shortcuts, and signing
  runs only on macOS — so .github/workflows/sign-shortcut.yml signs this on a
  cloud Mac (`shortcuts sign` with mode=anyone) into public/mipuy.shortcut.

  The device token is NOT embedded — it's filled once at import time via
  WFWorkflowImportQuestions (the user pastes their token from /connect).

  ⚠️ DEVICE-VALIDATION ITEMS (cannot be verified without an iPhone, iOS 17+):
    1. Merchant/Amount come from the transaction as Shortcut Input properties
       (Type=ExtensionInput + WFPropertyVariableAggrandizement PropertyName).
       If a standalone shortcut can't read those off the passed transaction,
       fall back to extracting them inside the automation (see guide).
    2. PropertyName strings ("Merchant" / "Amount") and the WFJSONValues /
       downloadurl parameter keys are best-effort from the reverse-engineered
       format; adjust on first real-device import if needed.

  Action indices (referenced by WFWorkflowImportQuestions.ActionIndex):
    0 = Text (token holder)         UUID A1111111-…
    1 = Replace Text (clean amount) UUID A2222222-…
    2 = Get Contents of URL (POST)
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>WFWorkflowClientVersion</key>
	<string>2607.0.2</string>
	<key>WFWorkflowMinimumClientVersion</key>
	<integer>900</integer>
	<key>WFWorkflowMinimumClientVersionString</key>
	<string>900</string>
	<key>WFWorkflowIcon</key>
	<dict>
		<key>WFWorkflowIconStartColor</key>
		<integer>-1000165</integer>
		<key>WFWorkflowIconGlyphNumber</key>
		<integer>59511</integer>
	</dict>
	<key>WFWorkflowTypes</key>
	<array>
		<string>NCWidget</string>
		<string>WatchKit</string>
	</array>
	<key>WFWorkflowInputContentItemClasses</key>
	<array>
		<string>WFAppStoreAppContentItem</string>
		<string>WFArticleContentItem</string>
		<string>WFContactContentItem</string>
		<string>WFDateContentItem</string>
		<string>WFEmailAddressContentItem</string>
		<string>WFGenericFileContentItem</string>
		<string>WFImageContentItem</string>
		<string>WFiTunesProductContentItem</string>
		<string>WFLocationContentItem</string>
		<string>WFDCMapsLinkContentItem</string>
		<string>WFAVAssetContentItem</string>
		<string>WFPDFContentItem</string>
		<string>WFPhoneNumberContentItem</string>
		<string>WFRichTextContentItem</string>
		<string>WFSafariWebPageContentItem</string>
		<string>WFStringContentItem</string>
		<string>WFURLContentItem</string>
	</array>

	<key>WFWorkflowImportQuestions</key>
	<array>
		<dict>
			<key>ParameterKey</key>
			<string>WFTextActionText</string>
			<key>Category</key>
			<string>Parameter</string>
			<key>ActionIndex</key>
			<integer>0</integer>
			<key>Text</key>
			<string>הדבק כאן את הטוקן האישי שלך (מתוך עמוד /connect)</string>
			<key>DefaultValue</key>
			<string></string>
		</dict>
	</array>

	<key>WFWorkflowActions</key>
	<array>

		<!-- 0: Text — holds the device token. Filled at import time by the question above. -->
		<dict>
			<key>WFWorkflowActionIdentifier</key>
			<string>is.workflow.actions.gettext</string>
			<key>WFWorkflowActionParameters</key>
			<dict>
				<key>UUID</key>
				<string>A1111111-1111-4111-8111-111111111111</string>
				<key>WFTextActionText</key>
				<string></string>
			</dict>
		</dict>

		<!-- 1: Replace Text — strip everything but digits and dot from the transaction Amount
		     (Apple Pay surfaces it like "29.00 ₪"). Input = Shortcut Input → Amount property. -->
		<dict>
			<key>WFWorkflowActionIdentifier</key>
			<string>is.workflow.actions.text.replace</string>
			<key>WFWorkflowActionParameters</key>
			<dict>
				<key>UUID</key>
				<string>A2222222-2222-4222-8222-222222222222</string>
				<key>WFReplaceTextRegularExpression</key>
				<true/>
				<key>WFReplaceTextCaseSensitive</key>
				<true/>
				<key>WFReplaceTextFind</key>
				<string>[^0-9.]</string>
				<key>WFReplaceTextReplace</key>
				<string></string>
				<key>WFInput</key>
				<dict>
					<key>Value</key>
					<dict>
						<key>Type</key>
						<string>ExtensionInput</string>
						<key>Aggrandizements</key>
						<array>
							<dict>
								<key>Type</key>
								<string>WFPropertyVariableAggrandizement</string>
								<key>PropertyName</key>
								<string>Amount</string>
							</dict>
						</array>
					</dict>
					<key>WFSerializationType</key>
					<string>WFTextTokenAttachment</string>
				</dict>
			</dict>
		</dict>

		<!-- 2: Get Contents of URL — POST JSON { token, merchant, amount } to the server. -->
		<dict>
			<key>WFWorkflowActionIdentifier</key>
			<string>is.workflow.actions.downloadurl</string>
			<key>WFWorkflowActionParameters</key>
			<dict>
				<key>WFURL</key>
				<string>https://mipuy-financi-app-2-3nay.vercel.app/api/transaction</string>
				<key>WFHTTPMethod</key>
				<string>POST</string>
				<key>ShowHeaders</key>
				<true/>
				<key>WFHTTPHeaders</key>
				<dict>
					<key>Value</key>
					<dict>
						<key>WFDictionaryFieldValueItems</key>
						<array>
							<dict>
								<key>WFItemType</key>
								<integer>0</integer>
								<key>WFKey</key>
								<dict>
									<key>Value</key>
									<dict>
										<key>string</key>
										<string>Content-Type</string>
									</dict>
									<key>WFSerializationType</key>
									<string>WFTextTokenString</string>
								</dict>
								<key>WFValue</key>
								<dict>
									<key>Value</key>
									<dict>
										<key>string</key>
										<string>application/json</string>
									</dict>
									<key>WFSerializationType</key>
									<string>WFTextTokenString</string>
								</dict>
							</dict>
						</array>
					</dict>
					<key>WFSerializationType</key>
					<string>WFDictionaryFieldValue</string>
				</dict>
				<key>WFHTTPBodyType</key>
				<string>JSON</string>
				<key>WFJSONValues</key>
				<dict>
					<key>Value</key>
					<dict>
						<key>WFDictionaryFieldValueItems</key>
						<array>

							<!-- token = output of action 0 (the Text/token action) -->
							<dict>
								<key>WFItemType</key>
								<integer>0</integer>
								<key>WFKey</key>
								<dict>
									<key>Value</key>
									<dict>
										<key>string</key>
										<string>token</string>
									</dict>
									<key>WFSerializationType</key>
									<string>WFTextTokenString</string>
								</dict>
								<key>WFValue</key>
								<dict>
									<key>Value</key>
									<dict>
										<key>OutputUUID</key>
										<string>A1111111-1111-4111-8111-111111111111</string>
										<key>Type</key>
										<string>ActionOutput</string>
										<key>OutputName</key>
										<string>Text</string>
									</dict>
									<key>WFSerializationType</key>
									<string>WFTextTokenAttachment</string>
								</dict>
							</dict>

							<!-- merchant = Shortcut Input → Merchant property -->
							<dict>
								<key>WFItemType</key>
								<integer>0</integer>
								<key>WFKey</key>
								<dict>
									<key>Value</key>
									<dict>
										<key>string</key>
										<string>merchant</string>
									</dict>
									<key>WFSerializationType</key>
									<string>WFTextTokenString</string>
								</dict>
								<key>WFValue</key>
								<dict>
									<key>Value</key>
									<dict>
										<key>Type</key>
										<string>ExtensionInput</string>
										<key>Aggrandizements</key>
										<array>
											<dict>
												<key>Type</key>
												<string>WFPropertyVariableAggrandizement</string>
												<key>PropertyName</key>
												<string>Merchant</string>
											</dict>
										</array>
									</dict>
									<key>WFSerializationType</key>
									<string>WFTextTokenAttachment</string>
								</dict>
							</dict>

							<!-- amount = output of action 1 (cleaned amount) -->
							<dict>
								<key>WFItemType</key>
								<integer>0</integer>
								<key>WFKey</key>
								<dict>
									<key>Value</key>
									<dict>
										<key>string</key>
										<string>amount</string>
									</dict>
									<key>WFSerializationType</key>
									<string>WFTextTokenString</string>
								</dict>
								<key>WFValue</key>
								<dict>
									<key>Value</key>
									<dict>
										<key>OutputUUID</key>
										<string>A2222222-2222-4222-8222-222222222222</string>
										<key>Type</key>
										<string>ActionOutput</string>
										<key>OutputName</key>
										<string>Updated Text</string>
									</dict>
									<key>WFSerializationType</key>
									<string>WFTextTokenAttachment</string>
								</dict>
							</dict>

						</array>
					</dict>
					<key>WFSerializationType</key>
					<string>WFDictionaryFieldValue</string>
				</dict>
			</dict>
		</dict>

	</array>
</dict>
</plist>
