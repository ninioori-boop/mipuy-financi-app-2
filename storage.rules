rules_version = '2';

// Client document intake. Clients upload files for the advisor to review and
// build a mapping from. A client writes/reads/deletes only their own folder;
// the advisor (emails below) may read everyone's. Additive — no other storage
// path is affected.
//
// NOTE: advisor emails are duplicated from src/lib/labAccess.ts (LAB_EMAILS)
// because Storage rules can't import app code. Keep the two in sync.
service firebase.storage {
  match /b/{bucket}/o {

    function isAdvisor() {
      return request.auth != null
        && request.auth.token.email in ['ninioori@gmail.com', 'eden00076@gmail.com'];
    }

    match /intake/{userId}/{fileName=**} {
      allow read:   if request.auth != null && (request.auth.uid == userId || isAdvisor());
      allow write:  if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.size < 25 * 1024 * 1024
                    && request.resource.contentType.matches('application/pdf|image/.*|text/.*|application/vnd.openxmlformats-officedocument.*|application/vnd.ms-excel|application/octet-stream');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Everything else: blocked.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
