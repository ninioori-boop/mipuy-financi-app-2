rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Advisor identification for cross-user reads (mirrors src/lib/labAccess.ts
    // LAB_EMAILS — rules can't import app code, keep the two in sync). Used ONLY
    // for the intake cross-read below. The advisor↔client management system
    // (clientLinks) does NOT use this — it keys off invitedByUid on the link.
    function isAdvisor() {
      return request.auth != null
        && request.auth.token.email in ['ninioori@gmail.com', 'eden00076@gmail.com'];
    }

    // Platform owner (super-admin) — reads the oversight ledger across all
    // practices. Membership doc is admin-managed (platformOwners/{uid}); it is
    // never exposed to clients (falls under the catch-all deny, read here with
    // rule privileges via exists()).
    function isOwner() {
      return request.auth != null
        && exists(/databases/$(database)/documents/platformOwners/$(request.auth.uid));
    }

    // The signed-in caller's own lowercased email, or '' when absent (guards the
    // clientLinks self-read below against a null token email).
    function callerEmail() {
      return request.auth != null && request.auth.token.email != null
        ? request.auth.token.email.lower() : '';
    }

    // ── User data — owner-only AND invite-only ────────────────────────
    // The owner reads/writes only their own document, AND their email must exist
    // in the `allowlist` collection. All 24 current users were seeded into the
    // allowlist (scripts/seed-allowlist.ts), so none are affected. A new, non-
    // invited email can create an auth account but cannot read/write any data —
    // so the app is unusable for them until the advisor adds their email.
    // (exists() runs with rule privileges, so `allowlist` stays private below.)
    match /users/{userId} {
      // UNCHANGED — owner-only + allowlist, read AND write:
      allow read, write: if request.auth != null
        && request.auth.uid == userId
        && exists(/databases/$(database)/documents/allowlist/$(request.auth.token.email));

      // NEW (additive, READ-ONLY): a consented advisor whose ACTIVE link names
      // them may read this client's financial doc. OR-combined, so the owner
      // clause above is never weakened. Read is granted at BOTH access tiers
      // (a write-consented advisor must still be able to read).
      allow read: if request.auth != null
        && exists(/databases/$(database)/documents/clientLinks/$(userId))
        && get(/databases/$(database)/documents/clientLinks/$(userId)).data.status == 'active'
        && get(/databases/$(database)/documents/clientLinks/$(userId)).data.invitedByUid == request.auth.uid;

      // NEW (additive, WRITE): a WRITE-tier consented advisor may edit this
      // client's financial doc. Gated on the client's explicit edit consent
      // (access=='write', set only by the client via setClientSharing). The
      // owner write clause above is untouched; dropping the link (status!='active')
      // or the tier (access!='write' — incl. auto-expiry at 'סוף תהליך') cuts
      // write instantly at the rule level.
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/clientLinks/$(userId))
        && get(/databases/$(database)/documents/clientLinks/$(userId)).data.status == 'active'
        && get(/databases/$(database)/documents/clientLinks/$(userId)).data.invitedByUid == request.auth.uid
        && get(/databases/$(database)/documents/clientLinks/$(userId)).data.access == 'write';
    }

    // ── Version history — per-user snapshot subcollection ─────────────
    // Rolling backups (up to 20 per user) written after each successful save,
    // throttled to ~one every 5 minutes. Same protection as the parent user
    // doc: owner-only + invite-only allowlist. Additive collection — the old
    // live app never touches it, so zero-risk to it.
    match /users/{userId}/versions/{versionId} {
      // UNCHANGED — owner-only + allowlist:
      allow read, write: if request.auth != null
        && request.auth.uid == userId
        && exists(/databases/$(database)/documents/allowlist/$(request.auth.token.email));

      // NEW (additive): a WRITE-tier consented advisor may read + write version
      // snapshots in the CLIENT's history — full transparency, the client can
      // rewind advisor edits. `write` covers create/delete (trimVersions caps at 20).
      allow read, write: if request.auth != null
        && exists(/databases/$(database)/documents/clientLinks/$(userId))
        && get(/databases/$(database)/documents/clientLinks/$(userId)).data.status == 'active'
        && get(/databases/$(database)/documents/clientLinks/$(userId)).data.invitedByUid == request.auth.uid
        && get(/databases/$(database)/documents/clientLinks/$(userId)).data.access == 'write';
    }

    // ── Shared category-learning DB ───────────────────────────────────
    // Cross-account merchant→category memory. Reads open to any signed-in user;
    // writes can only add/update keys inside `db`, never remove keys or replace
    // the doc with an arbitrary shape (blocks full-wipe and key-deletion attacks).
    match /shared/learnedDB {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['db'])
        && request.resource.data.db is map
        && request.resource.data.db.keys().size() <= 20000;
      allow update: if request.auth != null
        && request.resource.data.keys().hasOnly(['db'])
        && request.resource.data.db is map
        && request.resource.data.db.keys().size() <= 20000
        && request.resource.data.db.keys().hasAll(resource.data.db.keys());
    }

    // ── Auto-pushed transaction inbox ─────────────────────────────────
    // /api/transaction (admin SDK, bypassing rules) writes externally-pushed
    // charges (Apple Pay / Google Pay) here; the client drains them into its
    // expense log and deletes them. The owner may read+delete only its own items;
    // no client can create/forge items. Additive collection — the old live app
    // never touches it, so this is zero-risk to it.
    match /transactionInbox/{userId}/items/{itemId} {
      allow read, delete: if request.auth != null && request.auth.uid == userId;
      allow create, update: if false;
    }

    // ── Client document intake ────────────────────────────────────────
    // Clients upload files (in Storage) for the advisor to review; the metadata
    // lives here. A client reads/writes only their own intake; the advisor may
    // read everyone's to triage. Additive collection — the old live app never
    // touches it, so this is zero-risk to it.
    match /intake/{userId} {
      allow read:  if request.auth != null && (request.auth.uid == userId || isAdvisor());
      allow write: if request.auth != null && request.auth.uid == userId;

      match /files/{fileId} {
        allow read:  if request.auth != null && (request.auth.uid == userId || isAdvisor());
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── Advisor↔client management (additive; old live app never touches these) ──
    // Links written ONLY by callables (inviteClient / setClientSharing) via the
    // admin SDK, so every client write is blocked here. Reads:
    //  • the advisor who sent it (invitedByUid) — sees every status for their roster
    //  • the linked client (clientUid) — their own active/declined/revoked link
    //  • the invited client pre-registration (invitedEmail == own email) — to drive consent
    //  • the platform owner — the oversight ledger across all practices
    match /clientLinks/{linkId} {
      allow read: if request.auth != null && (
           resource.data.invitedByUid == request.auth.uid
        || resource.data.clientUid   == request.auth.uid
        || resource.data.invitedEmail == callerEmail()
        || isOwner()
      );
      allow write: if false;
    }

    // Advisor↔practice binding. An advisor reads only their own role doc (the
    // dashboard gate + practiceId); the owner reads all (oversight). Admin-write only.
    match /advisors/{advisorUid} {
      allow read: if request.auth != null && (request.auth.uid == advisorUid || isOwner());
      allow write: if false;
    }

    // A practice is readable by its member advisors and the owner. Admin-write only.
    match /practices/{practiceId} {
      allow read: if request.auth != null
        && (request.auth.uid in resource.data.advisorUids || isOwner());
      allow write: if false;
    }

    // The platform owner may read their OWN owner-record — the client-side gate
    // for the /app/admin oversight screen. No one else can read it (isOwner()
    // above still reads it with rule privileges for cross-collection checks).
    // Admin-write only.
    match /platformOwners/{ownerUid} {
      allow read: if request.auth != null && request.auth.uid == ownerUid;
      allow write: if false;
    }

    // ── Server-only collections (admin SDK; clients fully blocked) ────
    // `rateLimits`   — per-uid + global AI rate-limit counters (src/lib/rateLimit.ts).
    // `deviceTokens` — per-user device-token minVersion for revocation
    //                  (src/lib/deviceTokenRevocation.ts).
    // Both are written ONLY by API routes via the admin SDK (which bypasses rules);
    // no client ever touches them, so the catch-all below already denies all client
    // access. Documented here only — additive, the old live app never references them.

    // ── Everything else: blocked ──────────────────────────────────────
    // Includes `allowlist` (admin-managed, read only via exists() with rule
    // privileges above), the server-only `rateLimits`/`deviceTokens`, and the
    // still-unused invites/maps. The advisor system's clientLinks/advisors/
    // practices/platformOwners are matched explicitly above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
