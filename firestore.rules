rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User data ─────────────────────────────────────────────────────
    // Every authenticated user reads and writes only their own document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Shared category-learning DB ───────────────────────────────────
    // Cross-account merchant→category memory written by saveLearnedEntry.
    // Locked down so that:
    //   - reads remain open to any authenticated user (everyone benefits
    //     from the shared pool),
    //   - writes can only add or update keys inside `db`, never remove
    //     existing keys and never replace the doc with an arbitrary shape.
    // This blocks both a full-wipe attack (setDoc(.., {})) and a partial
    // key-deletion attack (updateDoc with FieldValue.delete()).
    match /shared/learnedDB {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['db'])
        && request.resource.data.db is map;
      allow update: if request.auth != null
        && request.resource.data.keys().hasOnly(['db'])
        && request.resource.data.db is map
        && request.resource.data.db.keys().hasAll(resource.data.db.keys());
    }

    // ── Everything else: blocked ──────────────────────────────────────
    // The advisor / invites / maps feature is not wired into the app's
    // UI, so its collections do not need rules. The catch-all denies
    // access to any other path.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
