rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // כל משתמש קורא/כותב רק את המסמך שלו
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // מפות פיננסיות — הלקוח עצמו בלבד (v2 אין יועצים)
    match /maps/{clientId} {
      allow read, write: if request.auth != null && request.auth.uid == clientId;
    }

    // מאגר סיווג משותף — כל משתמש מחובר קורא/כותב. מכיל רק מיפויי שם-עסק→קטגוריה,
    // ללא שום מידע אישי או פיננסי. מאפשר ללמידה לעבור בין כל החשבונות מאחורי הקלעים.
    match /shared/{docId} {
      allow read, write: if request.auth != null;
    }

    // כל שאר האוספים — חסומים לחלוטין
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
